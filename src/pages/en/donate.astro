---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout lang={lang} currentPath="/en/donate" title={t.donate.title}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
    <div class="text-6xl mb-6">💚</div>
    <h1 class="font-display text-3xl md:text-4xl font-bold text-ecvl-green-900 mb-4">{t.donate.title}</h1>
    <p class="text-gray-600 text-lg mb-3 max-w-xl mx-auto">{t.donate.subtitle}</p>
    <p class="text-sm text-gray-500 mb-10">{t.donate.taxInfo}</p>
    <a
      href="https://www.helloasso.com"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-ecvl-green-600 text-white font-bold px-10 py-4 rounded-full hover:bg-ecvl-green-700 transition-colors text-lg shadow-lg"
    >
      ❤️ {t.donate.cta}
    </a>
  </section>
</Layout>
