---
import Layout from '../../layouts/Layout.astro';
import EventCard from '../../components/EventCard.astro';
import { useTranslations, getLocalePath } from '../../i18n';
import type { HAEvent } from '../../types/events';
import eventsData from '../../data/events.json';

const lang = 'en';
const t = useTranslations(lang);
const currentPath = '/en/';
const events = eventsData as HAEvent[];
---

<Layout lang={lang} currentPath={currentPath} title={t.hero.title}>
  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-ecvl-green-900 min-h-[520px] md:min-h-[600px] flex items-center">
    <img
      src={`${import.meta.env.BASE_URL}/images/ecvl-hero.jpeg`}
      alt="Écologie Citoyenne pour Villeneuve-Loubet"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-40"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ecvl-green-900/90 via-ecvl-green-900/60 to-transparent"></div>
    <div class="relative w-full max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-widest rounded-full px-3.5 py-1.5 mb-6 border border-white/20">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          Villeneuve-Loubet · French Riviera
        </span>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white mb-5">
          {t.hero.title}
        </h1>
        <p class="text-lg md:text-xl text-ecvl-green-100 mb-8 leading-relaxed">
          {t.hero.subtitle}
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="#events" class="bg-ecvl-green-500 text-white font-semibold px-7 py-3.5 rounded-full hover:bg-ecvl-green-400 transition-colors shadow-lg shadow-ecvl-green-900/30">
            {t.hero.cta}
          </a>
          <a href="#activities" class="bg-white/10 backdrop-blur-sm border border-white/30 text-white font-semibold px-7 py-3.5 rounded-full hover:bg-white/20 transition-colors">
            {t.hero.learnMore}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 md:h-16">
        <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20L0 60Z" fill="#fef9f0" />
      </svg>
    </div>
  </section>

  <!-- ── Activities overview ───────────────────────────────────── -->
  <section id="activities" class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-ecvl-green-900 mb-3">
        {t.activities.title}
      </h2>
      <div class="w-12 h-1 bg-ecvl-earth-400 rounded-full mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a
        href={getLocalePath(lang, '/repair-cafe')}
        class="group bg-white rounded-2xl border border-ecvl-earth-100 shadow-sm hover:shadow-md hover:border-ecvl-earth-300 transition-all flex flex-col relative overflow-hidden"
      >
        <div class="h-44 overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}/images/repair-1.jpg`}
            alt="Volunteers at the Repair Café"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
        <div class="p-6 flex flex-col gap-3 flex-1">
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-ecvl-earth-700 transition-colors">
            {t.activities.repairCafe.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">{t.activities.repairCafe.short}</p>
          <span class="text-sm font-semibold text-ecvl-earth-600 group-hover:text-ecvl-earth-800 transition-colors flex items-center gap-1.5 mt-1">
            {t.activities.repairCafe.cta}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </div>
      </a>

      <a
        href={getLocalePath(lang, '/jardin-partage')}
        class="group bg-white rounded-2xl border border-ecvl-green-100 shadow-sm hover:shadow-md hover:border-ecvl-green-300 transition-all flex flex-col relative overflow-hidden"
      >
        <div class="h-44 overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}/images/jardin-1.jpg`}
            alt="Fresh vegetables from the shared garden"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
        <div class="p-6 flex flex-col gap-3 flex-1">
          <h3 class="font-bold text-lg text-gray-900 group-hover:text-ecvl-green-700 transition-colors">
            {t.activities.garden.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">{t.activities.garden.short}</p>
          <span class="text-sm font-semibold text-ecvl-green-600 group-hover:text-ecvl-green-800 transition-colors flex items-center gap-1.5 mt-1">
            {t.activities.garden.cta}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </span>
        </div>
      </a>

      <div class="bg-ecvl-earth-50 rounded-2xl border border-ecvl-earth-100 p-7 flex flex-col gap-4 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-24 h-24 bg-ecvl-earth-100 rounded-bl-full opacity-40"></div>
        <div class="text-4xl relative">🍑</div>
        <div class="flex-1">
          <h3 class="font-bold text-lg text-gray-900 mb-2">{t.activities.fruitPicking.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{t.activities.fruitPicking.short}</p>
        </div>
        <span class="text-xs font-semibold uppercase tracking-wider text-ecvl-earth-500 bg-ecvl-earth-100 px-3 py-1 rounded-full self-start">
          Seasonal activity
        </span>
      </div>
    </div>
  </section>

  <!-- ── Upcoming Events ───────────────────────────────────────── -->
  <section id="events" class="py-16 md:py-20 bg-ecvl-green-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">{t.events.title}</h2>
        <p class="text-ecvl-green-300">{t.events.subtitle}</p>
        <div class="w-12 h-1 bg-ecvl-earth-400 rounded-full mx-auto mt-4"></div>
      </div>
      {events.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {events.map((event) => (
            <EventCard event={event} lang={lang} />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10">
          <div class="text-5xl mb-4">📅</div>
          <p class="text-ecvl-green-200">{t.events.noEvents}</p>
          <a
            href="https://www.helloasso.com/associations/ecologie-citoyenne-pour-villeneuve-loubet#event"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-block text-sm font-semibold text-ecvl-earth-300 hover:text-ecvl-earth-200 transition-colors"
          >
            {t.events.viewAll} →
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- ── Donate ────────────────────────────────────────────────── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="relative rounded-3xl overflow-hidden">
      <img src={`${import.meta.env.BASE_URL}/images/ecvl-banner.jpeg`} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-ecvl-green-900/80 backdrop-blur-[2px]"></div>
      <div class="relative text-white px-8 py-14 md:py-20 text-center">
        <span class="inline-block text-4xl mb-5">💚</span>
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{t.donate.title}</h2>
        <p class="text-ecvl-green-100 text-lg mb-2 max-w-xl mx-auto">{t.donate.subtitle}</p>
        <p class="text-ecvl-green-300 text-sm mb-10">{t.donate.taxInfo}</p>
        <a
          href="https://www.helloasso.com/associations/ecologie-citoyenne-pour-villeneuve-loubet"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-ecvl-earth-400 hover:bg-ecvl-earth-300 text-white font-bold px-9 py-4 rounded-full transition-colors shadow-xl shadow-black/20 text-base"
        >
          ❤️ {t.donate.cta}
        </a>
      </div>
    </div>
  </section>
</Layout>
