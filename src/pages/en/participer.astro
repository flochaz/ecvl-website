---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, getLocalePath } from '../../i18n';

const lang = 'en';
const t = useTranslations(lang);
const tp = t.participate;
---

<Layout lang={lang} currentPath="/en/participer" title={tp.title}>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-ecvl-green-900 min-h-[360px] md:min-h-[420px] flex items-center">
    <img
      src={`${import.meta.env.BASE_URL}/images/ecvl-hero.jpeg`}
      alt="ECVL volunteers"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-30"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ecvl-green-900/90 via-ecvl-green-900/60 to-transparent"></div>
    <div class="relative w-full max-w-6xl mx-auto px-4 sm:px-6 py-14 md:py-20">
      <div class="max-w-2xl">
        <a
          href={getLocalePath(lang, '/')}
          class="inline-flex items-center gap-1.5 text-white/70 hover:text-white text-sm mb-6 transition-colors"
        >
          ← {t.nav.home}
        </a>
        <div class="text-5xl mb-4">🤝</div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-3">{tp.title}</h1>
        <p class="text-xl text-ecvl-green-200 italic">{tp.subtitle}</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12">
        <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20L0 60Z" fill="#fef9f0" />
      </svg>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 space-y-16">

    <!-- Intro -->
    <section class="text-center">
      <p class="text-lg text-gray-700 leading-relaxed max-w-2xl mx-auto">{tp.intro}</p>
    </section>

    <!-- Two activity cards -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <!-- Repair Café -->
      <div class="bg-white rounded-2xl border border-ecvl-earth-100 shadow-sm overflow-hidden flex flex-col">
        <div class="h-44 overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}/images/repair-1.jpg`}
            alt="Volunteers at the Repair Café"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="p-7 flex flex-col flex-1 gap-4">
          <div>
            <div class="text-3xl mb-2">🛠️</div>
            <h2 class="text-xl font-bold text-gray-900 mb-1">{tp.repairCafe.title}</h2>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-ecvl-earth-700 bg-ecvl-earth-50 border border-ecvl-earth-200 rounded-full px-3 py-1">
              📅 {tp.repairCafe.schedule}
            </span>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">{tp.repairCafe.description}</p>
          <ul class="space-y-2">
            {tp.repairCafe.tasks.map((task) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="w-1.5 h-1.5 rounded-full bg-ecvl-earth-400 shrink-0 mt-1.5"></span>
                {task}
              </li>
            ))}
          </ul>
          <a
            href={getLocalePath(lang, '/repair-cafe')}
            class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-ecvl-earth-600 hover:text-ecvl-earth-800 transition-colors"
          >
            Learn more about Repair Café →
          </a>
        </div>
      </div>

      <!-- Shared Garden -->
      <div class="bg-white rounded-2xl border border-ecvl-green-100 shadow-sm overflow-hidden flex flex-col">
        <div class="h-44 overflow-hidden">
          <img
            src={`${import.meta.env.BASE_URL}/images/jardin-1.jpg`}
            alt="The Abreuvoir shared garden"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="p-7 flex flex-col flex-1 gap-4">
          <div>
            <div class="text-3xl mb-2">🌿</div>
            <h2 class="text-xl font-bold text-gray-900 mb-1">{tp.garden.title}</h2>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-ecvl-green-700 bg-ecvl-green-50 border border-ecvl-green-200 rounded-full px-3 py-1">
              📅 {tp.garden.schedule}
            </span>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">{tp.garden.description}</p>
          <ul class="space-y-2">
            {tp.garden.tasks.map((task) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="w-1.5 h-1.5 rounded-full bg-ecvl-green-500 shrink-0 mt-1.5"></span>
                {task}
              </li>
            ))}
          </ul>
          <a
            href={getLocalePath(lang, '/jardin-partage')}
            class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-ecvl-green-600 hover:text-ecvl-green-800 transition-colors"
          >
            Learn more about the Shared Garden →
          </a>
        </div>
      </div>

    </section>

    <!-- HelloAsso full widget -->
    <section class="bg-ecvl-green-50 border border-ecvl-green-200 rounded-2xl p-8">
      <div class="text-center mb-6">
        <div class="text-4xl mb-3">✍️</div>
        <h2 class="text-2xl font-bold text-gray-900">{tp.widgetTitle}</h2>
      </div>
      <iframe
        id="haWidget"
        allowtransparency="true"
        scrolling="auto"
        src="https://www.helloasso.com/associations/ecologie-citoyenne-pour-villeneuve-loubet/adhesions/benevole/widget"
        style="width: 100%; height: 750px; border: none;"
        title="ECVL volunteer sign-up via HelloAsso"
        onload="window.addEventListener('message', function(e) { const dataHeight = e.data.height; const el = document.getElementById('haWidget'); if (dataHeight > parseFloat(el.style.height || 0)) { el.style.height = dataHeight + 'px'; } })"
      ></iframe>
    </section>

  </div>
</Layout>
