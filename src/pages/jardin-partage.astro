---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import { useTranslations, getLocalePath } from '../i18n';
import type { HAEvent } from '../types/events';
import eventsData from '../data/events.json';

const lang = 'fr';
const t = useTranslations(lang);
const tg = t.garden;

const allEvents = eventsData as HAEvent[];
const gardenEvents = allEvents.filter((e) =>
  e.title.toLowerCase().includes('jardin') ||
  e.title.toLowerCase().includes('garden') ||
  e.title.toLowerCase().includes('glan'),
);
---

<Layout lang={lang} currentPath="/jardin-partage" title={tg.title}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ecvl-green-900 min-h-[420px] md:min-h-[500px] flex items-center">
    <img
      src={`${import.meta.env.BASE_URL}images/jardin-banner.png`}
      alt="Le Jardin de l'Abreuvoir à Villeneuve-Loubet"
      class="absolute inset-0 w-full h-full object-cover object-center opacity-50"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ecvl-green-900/90 via-ecvl-green-900/55 to-transparent"></div>
    <div class="relative w-full max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-2xl">
        <a href={getLocalePath(lang, '/')} class="inline-flex items-center gap-1.5 text-white/70 hover:text-white text-sm mb-6 transition-colors">
          ← {t.nav.home}
        </a>
        <div class="text-5xl mb-4">🌱</div>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">{tg.title}</h1>
        <p class="text-xl text-ecvl-green-100 italic mb-6">{tg.subtitle}</p>
        <p class="text-ecvl-green-100 leading-relaxed">{tg.intro}</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12">
        <path d="M0 60L1440 60L1440 20C1200 60 960 0 720 20C480 40 240 0 0 20L0 60Z" fill="#fef9f0" />
      </svg>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 space-y-16">

    <!-- Photo gallery -->
    <section class="grid grid-cols-2 gap-4">
      <div class="rounded-2xl overflow-hidden shadow-md aspect-[4/3]">
        <img
          src={`${import.meta.env.BASE_URL}images/jardin-1.jpg`}
          alt="Légumes frais du jardin partagé"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
      <div class="rounded-2xl overflow-hidden shadow-md aspect-[4/3]">
        <img
          src={`${import.meta.env.BASE_URL}images/jardin-2.jpg`}
          alt="Récolte de patates douces au jardin"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    </section>

    <!-- What we grow + principles -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div class="bg-ecvl-green-50 rounded-2xl p-7">
        <h2 class="text-xl font-bold text-gray-900 mb-5">{tg.whatWeGrow.title}</h2>
        <ul class="space-y-3">
          {tg.whatWeGrow.items.map((item) => (
            <li class="flex items-center gap-3 text-gray-700">
              <span class="text-lg">🌿</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-7">
        <h2 class="text-xl font-bold text-gray-900 mb-5">{tg.principles.title}</h2>
        <ul class="space-y-3">
          {tg.principles.items.map((item) => (
            <li class="flex items-center gap-3 text-gray-700">
              <span class="w-2 h-2 rounded-full bg-ecvl-green-500 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- How to participate -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-8">{tg.participate.title}</h2>
      <ol class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {tg.participate.steps.map((step, i) => (
          <li class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col gap-3">
            <span class="w-9 h-9 rounded-full bg-ecvl-green-100 text-ecvl-green-700 font-bold flex items-center justify-center text-sm">
              {i + 1}
            </span>
            <p class="text-sm text-gray-700 leading-relaxed">{step}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- Fruit picking highlight -->
    <section class="bg-ecvl-earth-50 border border-ecvl-earth-200 rounded-2xl p-8 flex flex-col md:flex-row items-start md:items-center gap-6">
      <div class="text-6xl shrink-0">🍑</div>
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">{tg.fruitPicking.title}</h2>
        <p class="text-gray-700 leading-relaxed">{tg.fruitPicking.description}</p>
      </div>
    </section>

    <!-- Upcoming garden events -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">{tg.nextEvents}</h2>
      {gardenEvents.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {gardenEvents.map((event) => (
            <EventCard event={event} lang={lang} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-ecvl-green-50 rounded-2xl">
          <p class="text-gray-500 mb-4">{t.events.noEvents}</p>
          <a
            href="https://www.helloasso.com/associations/ecologie-citoyenne-pour-villeneuve-loubet/adhesions/benevole"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-ecvl-green-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-ecvl-green-700 transition-colors"
          >
            {t.events.viewAll}
          </a>
        </div>
      )}
    </section>

  </div>
</Layout>
