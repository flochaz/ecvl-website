---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath = '/', title, description } = Astro.props;
const t = useTranslations(lang);
const pageTitle = title ? `${title} | ${t.site.name}` : `${t.site.fullName} | ${t.site.name}`;
const pageDesc = description ?? t.site.description;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}images/logo.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-ecvl-cream text-gray-900 font-sans antialiased">
    <Header lang={lang} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
