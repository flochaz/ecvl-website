---
import type { Lang } from '../i18n';
import { useTranslations, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'fr' ? 'en' : 'fr';

// Compute equivalent path in the other language
function getOtherLangPath(): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  if (lang === 'fr') {
    return `${base}/en${currentPath}`;
  } else {
    // strip /en prefix
    const stripped = currentPath.replace(/^\/en/, '') || '/';
    return `${base}${stripped}`;
  }
}

const navLinks = [
  { href: getLocalePath(lang, '/'), label: t.nav.home },
  { href: getLocalePath(lang, '/repair-cafe'), label: t.nav.repairCafe },
  { href: getLocalePath(lang, '/jardin-partage'), label: t.nav.garden },
  { href: getLocalePath(lang, '/participer'), label: t.nav.participate },
];
---

<header class="bg-white/95 backdrop-blur-sm border-b border-ecvl-green-100 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalePath(lang, '/')} class="flex items-center gap-2.5 group">
        <img
          src={`${import.meta.env.BASE_URL}/images/logo.png`}
          alt="ECVL"
          class="w-10 h-10 object-contain shrink-0"
          transition:name="site-logo"
        />
        <div class="hidden sm:block leading-none">
          <span class="font-bold text-ecvl-green-900 text-sm tracking-tight block">{t.site.name}</span>
          <span class="text-[10px] text-ecvl-earth-500 font-medium uppercase tracking-wider block mt-0.5">Villeneuve-Loubet</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="text-sm font-medium text-gray-600 hover:text-ecvl-green-700 px-3 py-2 rounded-lg hover:bg-ecvl-green-50 transition-all"
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Right: donate CTA + lang switch + mobile menu -->
      <div class="flex items-center gap-2">
        <!-- Donate CTA -->
        <a
          href={getLocalePath(lang, '/don')}
          class="hidden md:inline-flex items-center gap-1.5 bg-ecvl-green-600 text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-ecvl-green-700 transition-colors shadow-sm"
        >
          <span class="text-xs">❤️</span>
          {t.nav.donate}
        </a>

        <!-- Language switch -->
        <a
          href={getOtherLangPath()}
          class="text-xs font-bold uppercase tracking-wider text-ecvl-green-700 border border-ecvl-green-200 rounded-lg px-2.5 py-1.5 hover:bg-ecvl-green-50 transition-colors"
          aria-label={`Switch to ${otherLang === 'fr' ? 'Français' : 'English'}`}
        >
          {otherLang === 'fr' ? 'FR' : 'EN'}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden md:hidden py-4 border-t border-gray-100">
      <div class="flex flex-col gap-1">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="text-sm font-medium text-gray-700 hover:text-ecvl-green-700 px-3 py-2 rounded-lg hover:bg-ecvl-green-50 transition-all">
            {label}
          </a>
        ))}
        <div class="pt-2 mt-1 border-t border-gray-100">
          <a
            href={getLocalePath(lang, '/don')}
            class="flex items-center justify-center gap-1.5 bg-ecvl-green-600 text-white px-4 py-2.5 rounded-full text-sm font-semibold hover:bg-ecvl-green-700 transition-colors"
          >
            <span class="text-xs">❤️</span>
            {t.nav.donate}
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
