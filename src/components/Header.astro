---
import type { Lang } from '../i18n';
import { useTranslations, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'fr' ? 'en' : 'fr';

// Compute equivalent path in the other language
function getOtherLangPath(): string {
  if (lang === 'fr') {
    return `/en${currentPath}`;
  } else {
    // strip /en prefix
    const stripped = currentPath.replace(/^\/en/, '') || '/';
    return stripped;
  }
}

const navLinks = [
  { href: getLocalePath(lang, '/'), label: t.nav.home },
  { href: getLocalePath(lang, '/repair-cafe'), label: t.nav.repairCafe },
  { href: getLocalePath(lang, '/jardin-partage'), label: t.nav.garden },
  { href: getLocalePath(lang, '/don'), label: t.nav.donate },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalePath(lang, '/')} class="flex items-center gap-2 group">
        <div class="w-9 h-9 bg-ecvl-green-600 rounded-full flex items-center justify-center shrink-0">
          <span class="text-white font-bold text-sm">🌿</span>
        </div>
        <div class="hidden sm:block">
          <span class="font-bold text-ecvl-green-800 text-sm leading-tight block">{t.site.name}</span>
          <span class="text-xs text-gray-500 leading-tight block">{lang === 'fr' ? 'Villeneuve-Loubet' : 'Villeneuve-Loubet'}</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="text-sm font-medium text-gray-700 hover:text-ecvl-green-700 transition-colors"
          >
            {label}
          </a>
        ))}
        <a
          href={getLocalePath(lang, '/don')}
          class="bg-ecvl-green-600 text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-ecvl-green-700 transition-colors"
        >
          {t.nav.donate}
        </a>
      </nav>

      <!-- Right: lang switch + mobile menu -->
      <div class="flex items-center gap-3">
        <!-- Language switch -->
        <a
          href={getOtherLangPath()}
          class="text-xs font-semibold uppercase tracking-wide text-ecvl-green-700 border border-ecvl-green-300 rounded px-2 py-1 hover:bg-ecvl-green-50 transition-colors"
          aria-label={`Switch to ${otherLang === 'fr' ? 'Français' : 'English'}`}
        >
          {otherLang === 'fr' ? 'FR' : 'EN'}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 pt-4">
      <div class="flex flex-col gap-3">
        {navLinks.map(({ href, label }) => (
          <a href={href} class="text-sm font-medium text-gray-700 hover:text-ecvl-green-700 transition-colors">
            {label}
          </a>
        ))}
        <a
          href={getLocalePath(lang, '/don')}
          class="bg-ecvl-green-600 text-white px-4 py-2 rounded-full text-sm font-semibold text-center hover:bg-ecvl-green-700 transition-colors"
        >
          {t.nav.donate}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
