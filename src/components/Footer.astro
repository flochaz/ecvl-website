---
import type { Lang } from '../i18n';
import { useTranslations, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-ecvl-green-900 text-ecvl-green-100 mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- About column -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 bg-ecvl-green-600 rounded-full flex items-center justify-center">
            <span class="text-white text-xs">🌿</span>
          </div>
          <span class="font-bold text-white">{t.site.name}</span>
        </div>
        <p class="text-sm text-ecvl-green-300 leading-relaxed">{t.site.description}</p>
        <p class="text-xs text-ecvl-green-500 mt-2">{t.footer.association}</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Navigation</h3>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalePath(lang, '/')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.home}</a></li>
          <li><a href={getLocalePath(lang, '/repair-cafe')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.repairCafe}</a></li>
          <li><a href={getLocalePath(lang, '/jardin-partage')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.garden}</a></li>
          <li><a href={getLocalePath(lang, '/don')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.donate}</a></li>
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <h3 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">{t.footer.followUs}</h3>
        <ul class="flex flex-col gap-2">
          <li>
            <a
              href="https://www.helloasso.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-ecvl-green-300 hover:text-white transition-colors flex items-center gap-2"
            >
              <span>❤️</span> HelloAsso
            </a>
          </li>
        </ul>
        <p class="text-xs text-ecvl-green-500 mt-4">Villeneuve-Loubet, Alpes-Maritimes</p>
      </div>
    </div>

    <div class="border-t border-ecvl-green-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ecvl-green-500">
      <span>© {year} {t.site.fullName}. {t.footer.rights}</span>
      <a href={getLocalePath(lang, '/mentions-legales')} class="hover:text-white transition-colors">{t.footer.legal}</a>
    </div>
  </div>
</footer>
