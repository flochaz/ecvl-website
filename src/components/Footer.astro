---
import type { Lang } from '../i18n';
import { useTranslations, getLocalePath } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-ecvl-green-900 text-ecvl-green-100 mt-0">
  <!-- Banner image strip -->
  <div class="h-32 overflow-hidden relative">
    <img src={`${import.meta.env.BASE_URL}/images/ecvl-banner.jpeg`} alt="" aria-hidden="true" class="w-full h-full object-cover object-center opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-b from-ecvl-green-900/60 to-ecvl-green-900"></div>
  </div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- About column -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <img
            src={`${import.meta.env.BASE_URL}/images/logo.png`}
            alt="ECVL"
            class="w-9 h-9 object-contain shrink-0"
          />
          <span class="font-bold text-white tracking-tight">{t.site.name}</span>
        </div>
        <p class="text-sm text-ecvl-green-300 leading-relaxed">{t.site.description}</p>
        <p class="text-xs text-ecvl-green-500 mt-3 font-medium uppercase tracking-wider">{t.footer.association}</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">Navigation</h3>
        <ul class="flex flex-col gap-2">
          <li><a href={getLocalePath(lang, '/')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.home}</a></li>
          <li><a href={getLocalePath(lang, '/repair-cafe')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.repairCafe}</a></li>
          <li><a href={getLocalePath(lang, '/jardin-partage')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.garden}</a></li>
          <li><a href={getLocalePath(lang, '/don')} class="text-sm text-ecvl-green-300 hover:text-white transition-colors">{t.nav.donate}</a></li>
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <h3 class="font-semibold text-white mb-4 text-xs uppercase tracking-widest">{t.footer.followUs}</h3>
        <ul class="flex flex-col gap-2">
          <li>
            <a
              href="https://www.helloasso.com/associations/ecologie-citoyenne-pour-villeneuve-loubet"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-ecvl-green-300 hover:text-white transition-colors flex items-center gap-2"
            >
              <span>❤️</span> HelloAsso
            </a>
          </li>
        </ul>
        <p class="text-xs text-ecvl-green-500 mt-5 flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          Villeneuve-Loubet, Alpes-Maritimes
        </p>
      </div>
    </div>

    <div class="border-t border-ecvl-green-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-ecvl-green-600">
      <span>© {year} {t.site.fullName}. {t.footer.rights}</span>
      <a href={getLocalePath(lang, '/mentions-legales')} class="hover:text-ecvl-green-300 transition-colors">{t.footer.legal}</a>
    </div>
  </div>
</footer>
