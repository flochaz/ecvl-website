---
import type { HAEvent } from '../types/events';
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  event: HAEvent;
  lang: Lang;
}

const { event, lang } = Astro.props;
const t = useTranslations(lang);

const start = new Date(event.startsAt);
const dateLabel = start.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const timeLabel = start.toLocaleTimeString(lang === 'fr' ? 'fr-FR' : 'en-GB', {
  hour: '2-digit',
  minute: '2-digit',
});
---

<article class="bg-white rounded-2xl border border-ecvl-green-100/60 shadow-md hover:shadow-xl hover:-translate-y-0.5 transition-all overflow-hidden flex flex-col">
  {event.imageUrl && (
    <div class="h-44 overflow-hidden">
      <img
        src={event.imageUrl}
        alt={event.title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 text-xs text-ecvl-green-700 font-semibold mb-2">
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <span class="capitalize">{dateLabel}</span>
      <span class="text-gray-300">·</span>
      <span class="text-gray-500 font-normal">{timeLabel}</span>
    </div>

    {event.place && (
      <div class="flex items-center gap-1.5 text-xs text-gray-400 mb-3">
        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{event.place}</span>
      </div>
    )}

    <h3 class="font-bold text-gray-900 text-base mb-2 leading-snug">{event.title}</h3>

    {event.description && (
      <p class="text-sm text-gray-500 leading-relaxed flex-1 line-clamp-3">{event.description}</p>
    )}

    <a
      href={event.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-flex items-center justify-center gap-2 bg-ecvl-green-600 text-white px-4 py-2.5 rounded-full text-sm font-semibold hover:bg-ecvl-green-700 transition-colors"
    >
      {t.events.register}
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
  </div>
</article>
